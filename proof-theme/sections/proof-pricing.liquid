{% render 'proof-checkout-url', section: section %}
<section class="pricing-section" id="pricing" aria-label="Pricing — Social Proof and Business Proof tiers">
  <div class="section-inner">
    <span class="section-label reveal">Simple pricing</span>
    <h2 class="section-h2 reveal reveal-delay-1">Two tiers. One obvious choice.</h2>
    <div class="pricing-grid reveal reveal-delay-2">
      <div class="pricing-card">
        <div class="pricing-tier">Social Proof</div>
        <div class="pricing-price">$0<span style="font-size:20px;color:var(--text-secondary)">/mo</span></div>
        <div class="pricing-price-note">After $499 hardware, free forever</div>
        <ul class="pricing-features">
          <li>Live Google Rating · S1</li>
          <li>Live Instagram Count · S2</li>
          <li>NFC one-tap review flow</li>
          <li>Celebration flag animation</li>
          <li>WiFi over-the-air updates</li>
        </ul>
      </div>
      <div class="pricing-card" style="border-left:0.5px solid var(--warm-border);">
        <div class="pricing-tier" style="color:var(--cream);">Business Proof</div>
        <div class="pricing-price">$25<span style="font-size:20px;color:var(--text-secondary)">/mo</span></div>
        <div class="pricing-price-note">Everything in Social Proof, plus:</div>
        <ul class="pricing-features">
          <li>Square & Shopify integration · S3</li>
          <li>Today's Promotion screen · S4</li>
          <li>Real-time orders + best seller</li>
          <li>Merchant dashboard access</li>
          <li>Priority support</li>
        </ul>
      </div>
    </div>
    <div class="reveal reveal-delay-3" style="margin-top:28px;display:flex;align-items:center;gap:28px;flex-wrap:wrap;">
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);letter-spacing:0.12em;">30-DAY MONEY-BACK GUARANTEE · NO ANNUAL CONTRACT · CANCEL ANYTIME</div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PROOF Pricing",
  "tag": "div",
  "class": "proof-section",
  "settings": [
    { "type": "product", "id": "product", "label": "Checkout product" },
    { "type": "url", "id": "demo_video_url", "label": "Demo / video link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "PROOF Pricing" }]
}
{% endschema %}
