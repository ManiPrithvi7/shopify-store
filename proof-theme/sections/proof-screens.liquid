{% render 'proof-checkout-url', section: section %}
<section class="screens-section" id="screens" aria-label="Four live display screens">
  <div class="section-inner">
    <span class="section-label reveal">Four live screens</span>
    <h2 class="section-h2 reveal reveal-delay-1">Everything that matters. Nothing that doesn't.</h2>
    <div class="screens-row">
      <div class="screen-card reveal">
        <div class="screen-card-top">
          <div class="screen-mini">
            <div class="screen-mini-stars">★ ★ ★ ★ ★</div>
            <div class="screen-mini-val">4.9</div>
            <div class="screen-mini-label">91 Google Reviews</div>
          </div>
        </div>
        <div class="screen-card-body">
          <div class="screen-free-badge">✦ Free forever</div>
          <div class="screen-card-tag">S1</div>
          <div class="screen-card-h3">Google Rating</div>
          <div class="screen-card-desc">Live rating and review count. Updates automatically.</div>
        </div>
      </div>
      <div class="screen-card reveal reveal-delay-1">
        <div class="screen-card-top">
          <div class="screen-mini">
            <div class="screen-mini-ig" style="font-family:var(--font-serif);">12.4K</div>
            <div class="screen-mini-label" style="margin-top:4px;">Instagram Followers</div>
          </div>
        </div>
        <div class="screen-card-body">
          <div class="screen-free-badge">✦ Free forever</div>
          <div class="screen-card-tag">S2</div>
          <div class="screen-card-h3">Instagram</div>
          <div class="screen-card-desc">Live follower count. Social proof for walk-ins.</div>
        </div>
      </div>
      <div class="screen-card reveal reveal-delay-2">
        <div class="screen-card-top">
          <div class="screen-mini">
            <div class="screen-mini-val" style="font-size:28px;">2,847</div>
            <div class="screen-mini-label">Orders This Month</div>
            <div style="margin-top:8px;font-size:11px;color:var(--gold);font-family:var(--font-mono);letter-spacing:1px;">Best Seller: Oat Latte</div>
          </div>
        </div>
        <div class="screen-card-body">
          <div class="screen-free-badge" style="background:rgba(201,168,76,0.15);border-color:rgba(201,168,76,0.4);">$25/mo</div>
          <div class="screen-card-tag">S3</div>
          <div class="screen-card-h3">Orders & Best Seller</div>
          <div class="screen-card-desc">POS-integrated. Square & Shopify supported.</div>
        </div>
      </div>
      <div class="screen-card reveal reveal-delay-3">
        <div class="screen-card-top">
          <div class="screen-mini">
            <div class="screen-mini-label">Today Only</div>
            <div class="screen-mini-val" style="font-size:22px;color:var(--gold);">20% Off</div>
            <div class="screen-mini-label" style="margin-top:4px;">Cold Brew · Code: COLD</div>
          </div>
        </div>
        <div class="screen-card-body">
          <div class="screen-free-badge" style="background:rgba(201,168,76,0.15);border-color:rgba(201,168,76,0.4);">$25/mo</div>
          <div class="screen-card-tag">S4</div>
          <div class="screen-card-h3">Today's Promotion</div>
          <div class="screen-card-desc">Push daily specials. Update from your merchant dashboard.</div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PROOF Screens",
  "tag": "div",
  "class": "proof-section",
  "settings": [
    { "type": "product", "id": "product", "label": "Checkout product" },
    { "type": "url", "id": "demo_video_url", "label": "Demo / video link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "PROOF Screens" }]
}
{% endschema %}
