<section
  class="proof-embed-rail"
  id="proof-embed-rail"
  aria-label="Store assistance"
  {{ section.shopify_attributes }}
>
  <div class="proof-embed-rail__inner">
    <div class="proof-embed-slot proof-embed-slot--sales" data-embed-target="sales-pop">
      <span class="proof-embed-slot__icon" aria-hidden="true">◆</span>
      <span class="proof-embed-slot__label">{{ section.settings.sales_label }}</span>
      <span class="proof-embed-slot__hint">{{ section.settings.sales_hint }}</span>
    </div>
    <div class="proof-embed-slot proof-embed-slot--chat" data-embed-target="inbox">
      <span class="proof-embed-slot__icon" aria-hidden="true">✉</span>
      <span class="proof-embed-slot__label">{{ section.settings.chat_label }}</span>
      <span class="proof-embed-slot__hint">{{ section.settings.chat_hint }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PROOF Embed rail",
  "tag": "section",
  "class": "proof-embed-rail-section",
  "settings": [
    {
      "type": "text",
      "id": "sales_label",
      "label": "Sales pop label",
      "default": "Recent orders"
    },
    {
      "type": "text",
      "id": "sales_hint",
      "label": "Sales pop hint",
      "default": "Sales Pop appears here when enabled under App embeds"
    },
    {
      "type": "text",
      "id": "chat_label",
      "label": "Chat label",
      "default": "Questions about PROOF?"
    },
    {
      "type": "text",
      "id": "chat_hint",
      "label": "Chat hint",
      "default": "Shopify Inbox — enable in App embeds"
    }
  ],
  "presets": [
    {
      "name": "PROOF Embed rail"
    }
  ]
}
{% endschema %}
