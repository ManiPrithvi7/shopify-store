{% render 'proof-checkout-url', section: section %}
<div id="proof-landing" class="proof-landing-root" data-product-url="{{ product_url }}">
<!-- STICKY BUY BAR -->
<div class="sticky-bar" id="sticky-bar">
  <div class="sb-left">
    <div class="sb-logo">PROOF<span>.</span></div>
    <div class="sb-divider"></div>
    <div class="sb-tagline"><strong>Trust infrastructure</strong> for physical businesses</div>
  </div>
  <div class="sb-right">
    <div class="sb-guarantee">No app · No subscription · Free shipping<br>60-day returns — no questions</div>
    <a href="{{ product_url }}" class="btn btn-gold">Order Now — $499</a>
  </div>
</div>

<!-- NAV -->
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav id="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-logo">PROOF<span>.</span></div>
  <ul class="nav-links">
    <li><a href="#mechanism">How it Works</a></li>
    <li><a href="#why">Why it Works</a></li>
    <li><a href="#simulator">Projection</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#customers">Customers</a></li>
  </ul>
  <div class="nav-cta">
    <a href="{{ product_url }}" class="btn btn-gold">Order Now — $499</a>
  </div>
</nav>

