<!-- TRUST BAR -->

<!-- ══ ETHICAL ALTERNATIVE ══ -->
<div style="background:var(--surface-base);border-top:1px solid rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.04);">
  <div class="ethical-grid" style="max-width:1160px;margin:0 auto;padding:36px 60px;display:grid;grid-template-columns:1fr 1fr;gap:0;align-items:stretch;">

    <!-- Left: the problem with fake reviews -->
    <div style="padding:28px 40px 28px 0;border-right:1px solid rgba(255,255,255,.05);">
      <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:rgba(92,92,87,.45);margin-bottom:14px;">The shortcut that backfires</div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="color:rgba(157,34,53,.5);font-size:12px;flex-shrink:0;margin-top:1px;">✕</span>
          <span style="font-size:13px;color:rgba(184,184,173,.4);line-height:1.55;">Fake reviews get removed by Google — often taking your rating down with them</span>
        </div>
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="color:rgba(157,34,53,.5);font-size:12px;flex-shrink:0;margin-top:1px;">✕</span>
          <span style="font-size:13px;color:rgba(184,184,173,.4);line-height:1.55;">Customers spot inauthentic patterns — generic language, sudden bursts, no context</span>
        </div>
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="color:rgba(157,34,53,.5);font-size:12px;flex-shrink:0;margin-top:1px;">✕</span>
          <span style="font-size:13px;color:rgba(184,184,173,.4);line-height:1.55;">Google's policy violations can suspend your Business Profile entirely</span>
        </div>
      </div>
    </div>

    <!-- Right: the PROOF way -->
    <div style="padding:28px 0 28px 40px;">
      <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,168,76,.45);margin-bottom:14px;">The way that actually works</div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="color:rgba(82,183,136,.5);font-size:12px;flex-shrink:0;margin-top:1px;">✓</span>
          <span style="font-size:13px;color:rgba(184,184,173,.55);line-height:1.55;">Real reviews from real customers — earned in the moment they're most likely to leave one</span>
        </div>
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="color:rgba(82,183,136,.5);font-size:12px;flex-shrink:0;margin-top:1px;">✓</span>
          <span style="font-size:13px;color:rgba(184,184,173,.55);line-height:1.55;">No Google policy risk. No suspension risk. No reputation risk.</span>
        </div>
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="color:rgba(82,183,136,.5);font-size:12px;flex-shrink:0;margin-top:1px;">✓</span>
          <span style="font-size:13px;color:rgba(184,184,173,.55);line-height:1.55;">Reviews that compound — each one makes the next more likely</span>
        </div>
      </div>
      <p style="font-family:var(--font-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:rgba(201,168,76,.35);margin-top:20px;line-height:1.7;">PROOF doesn't manufacture reviews.<br>It earns them.</p>
    </div>

  </div>
</div>

<div class="trust-bar">
  <div class="trust-item"><span class="trust-icon">✦</span>Business-grade hardware</div>
  <div class="trust-item"><span class="trust-icon">✦</span>Plug-and-play WiFi setup</div>
  <div class="trust-item"><span class="trust-icon">✦</span>Google · Instagram · Square</div>
  <div class="trust-item"><span class="trust-icon">✦</span>60-day money-back guarantee</div>
  <div class="trust-item"><span class="trust-icon">✦</span>Ships within 5 business days</div>
</div>
{% render 'proof-section-apps' %}

{% schema %}
{
  "name": "PROOF Ticker & trust",
  "tag": "section",
  "class": "proof-section",
  "settings": [
    { "type": "product", "id": "product", "label": "Checkout product" },
    { "type": "url", "id": "demo_video_url", "label": "90-sec demo link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "PROOF Ticker & trust" }]
}
{% endschema %}
