{% render 'proof-checkout-url', section: section %}
<section class="testimonials-section" id="testimonials" aria-label="Founding merchant testimonials">
  <div class="section-inner">
    <span class="section-label reveal">Founding merchants</span>
    <h2 class="section-h2 reveal reveal-delay-1">From the counter.</h2>
    <div class="testimonials-grid">
      <div class="testimonial-card reveal spotlight-card">
        <div class="testimonial-stars">★★★★★</div>
        <div class="testimonial-quote">"Customers started commenting on it the first week. 'Is that live?' Yes. It is."</div>
        <div class="testimonial-author">
          <div class="testimonial-avatar">A</div>
          <div>
            <div class="testimonial-name">Ashley M.</div>
            <div class="testimonial-biz">Foxtail Coffee · Portland, OR</div>
          </div>
        </div>
      </div>
      <div class="testimonial-card reveal reveal-delay-1 spotlight-card">
        <div class="testimonial-stars">★★★★★</div>
        <div class="testimonial-quote">"We went from 47 to 91 reviews in eight weeks. Our Google ranking jumped. I don't touch it."</div>
        <div class="testimonial-author">
          <div class="testimonial-avatar">J</div>
          <div>
            <div class="testimonial-name">James R.</div>
            <div class="testimonial-biz">North End Cuts · Portland, OR</div>
          </div>
        </div>
      </div>
      <div class="testimonial-card reveal reveal-delay-2 spotlight-card">
        <div class="testimonial-stars">★★★★★</div>
        <div class="testimonial-quote">"The gold base matches my whole aesthetic. It looks like it belongs. Not like a gadget."</div>
        <div class="testimonial-author">
          <div class="testimonial-avatar">S</div>
          <div>
            <div class="testimonial-name">Sofia K.</div>
            <div class="testimonial-biz">Bloom Boutique · Portland, OR</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "PROOF Testimonials",
  "tag": "div",
  "class": "proof-section",
  "settings": [
    { "type": "product", "id": "product", "label": "Checkout product" },
    { "type": "url", "id": "demo_video_url", "label": "Demo / video link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "PROOF Testimonials" }]
}
{% endschema %}
