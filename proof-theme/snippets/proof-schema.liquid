{%- liquid
  assign proof_product = settings.proof_checkout_product
  if proof_product != blank
    assign schema_product_url = shop.url | append: proof_product.url
    assign schema_price = proof_product.price | money_without_currency | strip
  else
    assign schema_product_url = shop.url | append: '/products/proof-display-test'
    assign schema_price = '499'
  endif
  assign schema_page_url = shop.url | append: request.path
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "@id": {{ schema_product_url | append: '#product' | json }},
      "name": "PROOF Display",
      "description": "A $499 countertop NFC hardware device for cafés, salons, and boutiques. Shows live Google rating, Instagram follower count, POS orders, and today's promotion on a 10.1-inch display. One NFC tap opens the Google review form in under 8 seconds. Free Social Proof tier forever after hardware purchase.",
      "brand": { "@type": "Brand", "name": "Proof Nexus" },
      "manufacturer": {
        "@type": "Organization",
        "name": "Proof Nexus Inc",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Portland",
          "addressRegion": "OR",
          "addressCountry": "US"
        }
      },
      "offers": {
        "@type": "Offer",
        "price": {{ schema_price | json }},
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "url": {{ schema_product_url | json }},
        "seller": { "@type": "Organization", "name": "Proof Nexus Inc" },
        "priceValidUntil": "2026-12-31",
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": 30,
          "returnMethod": "https://schema.org/ReturnByMail"
        }
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "3",
        "bestRating": "5",
        "worstRating": "1"
      },
      "review": [
        {
          "@type": "Review",
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "author": { "@type": "Person", "name": "Ashley M." },
          "reviewBody": "Customers started commenting on it the first week. Is that live? Yes. It is.",
          "datePublished": "2026-02-14",
          "publisher": { "@type": "Organization", "name": "Foxtail Coffee" }
        },
        {
          "@type": "Review",
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "author": { "@type": "Person", "name": "James R." },
          "reviewBody": "We went from 47 to 91 reviews in eight weeks. Our Google ranking jumped. I don't touch it.",
          "datePublished": "2026-02-28",
          "publisher": { "@type": "Organization", "name": "North End Cuts" }
        },
        {
          "@type": "Review",
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "author": { "@type": "Person", "name": "Sofia K." },
          "reviewBody": "The gold base matches my whole aesthetic. It looks like it belongs. Not like a gadget.",
          "datePublished": "2026-03-10",
          "publisher": { "@type": "Organization", "name": "Bloom Boutique" }
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": {{ schema_page_url | append: '#faq' | json }},
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a countertop trust display?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A countertop trust display is a physical device that sits on your counter and shows your live Google rating, review count, and social proof in real time. PROOF Display uses a 10.1-inch screen and an NFC base — customers tap their phone to the base and the Google review form opens instantly."
          }
        },
        {
          "@type": "Question",
          "name": "What is PROOF Display?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "PROOF Display is a $499 countertop hardware device for cafés, salons, and boutiques. It shows your live Google rating, Instagram follower count, POS orders, and daily promotions on a 10.1-inch display. Customers tap the NFC base and the Google review form opens in under 8 seconds. The Social Proof tier is free forever after the one-time hardware purchase."
          }
        },
        {
          "@type": "Question",
          "name": "Do NFC taps work better than QR codes for getting reviews?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. NFC taps convert to completed reviews at approximately 7× the rate of QR codes. NFC happens at the moment of satisfaction on the counter; QR happens later at home after the moment is gone."
          }
        },
        {
          "@type": "Question",
          "name": "What is the 30-day pilot guarantee?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If PROOF Display does not generate a measurable increase in your Google review velocity within 30 days of installation, return it for a full refund. No restocking fee. Free return shipping. The guarantee covers the $499 hardware purchase only."
          }
        }
      ]
    },
    {
      "@type": "Dataset",
      "@id": {{ schema_page_url | append: '#dataset' | json }},
      "name": "NFC vs QR Code Review Conversion: Portland Pilot Data 2026",
      "description": "Study of 10 Portland small businesses measuring Google review conversion rates from NFC tap interactions versus QR code receipt prompts over a 60-day period.",
      "keywords": ["NFC review conversion", "QR code review conversion", "Google review generation", "countertop display"],
      "temporalCoverage": "2026-01/2026-03",
      "spatialCoverage": { "@type": "Place", "name": "Portland, Oregon, United States" },
      "publisher": { "@type": "Organization", "name": "Proof Nexus Inc" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | json }} },
        { "@type": "ListItem", "position": 2, "name": "PROOF Display", "item": {{ schema_product_url | json }} }
      ]
    }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["#speakable-hero", "#speakable-results", "#speakable-proof-way", "#speakable-what-is"]
  }
}
</script>
