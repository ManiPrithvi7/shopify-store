{% render 'proof-checkout-url', section: section %}
<!-- ══ PLACEMENT ══ -->
<section class="s placement" id="placement">
  <div class="inner">
    <div class="eyebrow">Where merchants place it</div>
    <h2>Designed to fit<br><em>your space.</em></h2>
    <p class="sub" style="margin-top:12px;max-width:440px;">Compact footprint. Premium materials. PROOF sits naturally wherever your customers' eyes land.</p>
    <div class="placement-grid reveal-stagger">
      <!-- CAFE COUNTER -->
      <div class="place-card">
        <div class="place-diagram">
          <svg class="place-svg" viewBox="0 0 200 150" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="90" width="180" height="16" rx="2" fill="#2e2e2b"/>
            <rect x="10" y="104" width="180" height="40" rx="2" fill="#242422"/>
            <rect x="75" y="54" width="50" height="38" rx="3" fill="#3d3d39" stroke="rgba(201,168,76,0.4)" stroke-width="1"/>
            <rect x="78" y="57" width="44" height="28" rx="1" fill="#1a1a18"/>
            <text x="100" y="74" text-anchor="middle" font-size="6" fill="#c9a84c" font-family="serif" font-weight="bold">4.9★</text>
            <rect x="75" y="54" width="50" height="38" rx="3" fill="none" stroke="rgba(201,168,76,0.15)" stroke-width="4"/>
            <line x1="112" y1="30" x2="112" y2="56" stroke="#aaa" stroke-width="1.5"/>
            <rect x="112" y="22" width="18" height="12" rx="1" fill="#242422" stroke="rgba(255,255,255,0.15)" stroke-width="0.5"/>
            <rect x="30" y="76" width="14" height="16" rx="2" fill="#3d3d39"/>
            <rect x="156" y="76" width="14" height="16" rx="2" fill="#3d3d39"/>
            <text x="100" y="136" text-anchor="middle" font-size="8" fill="#5c5c57" font-family="sans-serif">front counter</text>
          </svg>
        </div>
        <div class="place-loc">☕ Café</div>
        <div class="place-name">Front Counter</div>
        <div class="place-desc">PROOF sits on the counter where every customer sees it — between the POS and the coffee machine. Customers waiting for their order have time to notice your 4.9★ and think about leaving one too.</div>
      </div>
      <!-- RECEPTION -->
      <div class="place-card">
        <div class="place-diagram">
          <svg class="place-svg" viewBox="0 0 200 150" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="88" width="180" height="16" rx="2" fill="#2e2e2b"/>
            <rect x="10" y="102" width="180" height="42" rx="2" fill="#242422"/>
            <rect x="28" y="65" width="48" height="30" rx="2" fill="#3d3d39"/>
            <rect x="31" y="68" width="42" height="24" rx="1" fill="#1a1a18"/>
            <rect x="22" y="95" width="60" height="4" rx="1" fill="#2e2e2b"/>
            <rect x="118" y="54" width="50" height="36" rx="3" fill="#3d3d39" stroke="rgba(201,168,76,0.4)" stroke-width="1"/>
            <rect x="121" y="57" width="44" height="27" rx="1" fill="#1a1a18"/>
            <text x="143" y="73" text-anchor="middle" font-size="6" fill="#c9a84c" font-family="serif" font-weight="bold">4.9★</text>
            <rect x="118" y="54" width="50" height="36" rx="3" fill="none" stroke="rgba(201,168,76,0.15)" stroke-width="4"/>
            <line x1="155" y1="30" x2="155" y2="56" stroke="#aaa" stroke-width="1.5"/>
            <rect x="155" y="22" width="18" height="12" rx="1" fill="#242422" stroke="rgba(255,255,255,0.15)" stroke-width="0.5"/>
            <text x="100" y="136" text-anchor="middle" font-size="8" fill="#5c5c57" font-family="sans-serif">reception desk</text>
          </svg>
        </div>
        <div class="place-loc">✂️ Salon</div>
        <div class="place-name">Reception Desk</div>
        <div class="place-desc">PROOF sits beside your booking system, visible the moment new clients walk in. Before a word is spoken, they've already seen that 200 people trusted you with their hair.</div>
      </div>
      <!-- CHECKOUT -->
      <div class="place-card">
        <div class="place-diagram">
          <svg class="place-svg" viewBox="0 0 200 150" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="88" width="180" height="16" rx="2" fill="#2e2e2b"/>
            <rect x="10" y="102" width="180" height="42" rx="2" fill="#242422"/>
            <rect x="30" y="58" width="36" height="34" rx="3" fill="#3d3d39"/>
            <rect x="33" y="61" width="30" height="22" rx="1" fill="#1a1a18"/>
            <rect x="38" y="85" width="20" height="8" rx="1" fill="#2e2e2b"/>
            <rect x="36" y="72" width="26" height="8" rx="1" fill="#242422"/>
            <rect x="120" y="52" width="52" height="38" rx="3" fill="#3d3d39" stroke="rgba(201,168,76,0.4)" stroke-width="1"/>
            <rect x="123" y="55" width="46" height="28" rx="1" fill="#1a1a18"/>
            <text x="146" y="72" text-anchor="middle" font-size="6" fill="#c9a84c" font-family="serif" font-weight="bold">4.9★</text>
            <rect x="120" y="52" width="52" height="38" rx="3" fill="none" stroke="rgba(201,168,76,0.15)" stroke-width="4"/>
            <line x1="158" y1="28" x2="158" y2="54" stroke="#aaa" stroke-width="1.5"/>
            <rect x="158" y="20" width="18" height="12" rx="1" fill="#242422" stroke="rgba(255,255,255,0.15)" stroke-width="0.5"/>
            <text x="100" y="136" text-anchor="middle" font-size="8" fill="#5c5c57" font-family="sans-serif">retail checkout</text>
          </svg>
        </div>
        <div class="place-loc">🛍️ Retail</div>
        <div class="place-name">Checkout Counter</div>
        <div class="place-desc">PROOF sits next to your POS terminal. As customers pay, they see your reputation — right when their experience is freshest and the impulse to review is strongest.</div>
      </div>
      <!-- HOST STAND -->
      <div class="place-card">
        <div class="place-diagram">
          <svg class="place-svg" viewBox="0 0 200 150" xmlns="http://www.w3.org/2000/svg">
            <rect x="70" y="60" width="60" height="60" rx="2" fill="#2e2e2b"/>
            <rect x="72" y="62" width="56" height="56" rx="1" fill="#242422"/>
            <rect x="60" y="118" width="80" height="6" rx="1" fill="#1a1a18"/>
            <rect x="82" y="38" width="36" height="28" rx="2" fill="#3d3d39" stroke="rgba(201,168,76,0.4)" stroke-width="1"/>
            <rect x="85" y="41" width="30" height="20" rx="1" fill="#1a1a18"/>
            <text x="100" y="54" text-anchor="middle" font-size="5" fill="#c9a84c" font-family="serif" font-weight="bold">4.9★</text>
            <rect x="82" y="38" width="36" height="28" rx="2" fill="none" stroke="rgba(201,168,76,0.12)" stroke-width="4"/>
            <line x1="108" y1="18" x2="108" y2="40" stroke="#aaa" stroke-width="1.5"/>
            <rect x="108" y="11" width="14" height="10" rx="1" fill="#242422" stroke="rgba(255,255,255,0.15)" stroke-width="0.5"/>
            <rect x="76" y="80" width="48" height="30" rx="1" fill="#3d3d39"/>
            <line x1="100" y1="83" x2="100" y2="107" stroke="#1a1a18" stroke-width="1"/>
            <text x="100" y="136" text-anchor="middle" font-size="8" fill="#5c5c57" font-family="sans-serif">host stand</text>
          </svg>
        </div>
        <div class="place-loc">🍽️ Restaurant</div>
        <div class="place-name">Host Stand</div>
        <div class="place-desc">PROOF stands at your host stand, visible from the door. Guests waiting to be seated read reviews from previous diners — real people who sat in the same chairs.</div>
      </div>
    </div>
  </div>
</section>
{% render 'proof-section-apps' %}

{% schema %}
{
  "name": "PROOF Placement",
  "tag": "section",
  "class": "proof-section",
  "settings": [
    { "type": "product", "id": "product", "label": "Checkout product" },
    { "type": "url", "id": "demo_video_url", "label": "90-sec demo link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "PROOF Placement" }]
}
{% endschema %}
