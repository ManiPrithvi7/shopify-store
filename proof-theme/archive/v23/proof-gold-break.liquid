{% render 'proof-checkout-url', section: section %}
<!-- ══ GOLD BREAK — KEY METRICS ══ -->
<div class="gold-break">
  <div class="gold-break-inner reveal-stagger">
    <div class="gb-stat">
      <div class="gb-num">3×</div>
      <div class="gb-lbl">Review velocity</div>
      <div class="gb-sub">Avg. lift in first 30 days</div>
    </div>
    <div class="gb-stat">
      <div class="gb-num">4.8★</div>
      <div class="gb-lbl">Merchant satisfaction</div>
      <div class="gb-sub">Average across early merchants</div>
    </div>
    <div class="gb-stat">
      <div class="gb-num">#1–3</div>
      <div class="gb-lbl">Maps ranking</div>
      <div class="gb-sub">Working the same day</div>
    </div>
  </div>
</div>
{% render 'proof-section-apps' %}

{% schema %}
{
  "name": "PROOF Key metrics",
  "tag": "section",
  "class": "proof-section",
  "settings": [
    { "type": "product", "id": "product", "label": "Checkout product" },
    { "type": "url", "id": "demo_video_url", "label": "90-sec demo link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "PROOF Key metrics" }]
}
{% endschema %}
