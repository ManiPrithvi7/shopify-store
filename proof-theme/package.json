{
  "name": "proof-theme",
  "version": "1.0.0",
  "description": "[![Build status](https://github.com/shopify/dawn/actions/workflows/ci.yml/badge.svg?branch=main)](https://github.com/Shopify/dawn/actions/workflows/ci.yml?query=branch%3Amain) [![PRs Welcome](https://img.shields.io/badge/PRs-welcome-brightgreen.svg?color=informational)](/.github/CONTRIBUTING.md)",
  "type": "commonjs",
  "scripts": {
    "dev": "run-p -sr shopify:dev vite:dev",
    "deploy": "run-s vite:build shopify:push",
    "shopify:dev": "shopify theme dev --environment development --ignore \"assets/.vite/**\"",
    "postvite:build": "rm -rf assets/.vite",
    "shopify:push": "shopify theme push --environment development",
    "auth": "shopify auth login",
    "vite:dev": "vite",
    "vite:build": "vite build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shopify/dawn.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Shopify/dawn/issues"
  },
  "homepage": "https://github.com/Shopify/dawn#readme",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21",
    "vite-plugin-shopify": "^4.1.2"
  }
}
